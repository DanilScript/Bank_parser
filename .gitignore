# Исключаем виртуальное окружение Python (локально у каждого своё, весит много)
.venv/

# Исключаем служебные кэш-файлы Python (создаются автоматически)
__pycache__/

# Исключаем системные файлы macOS (мусор, создаётся Finder)
.DS_Store

# Исключаем входные данные (банковские выписки, личные данные)
data/input/

# Исключаем выходные файлы (результаты работы программы, генерируются автоматически)
data/output/